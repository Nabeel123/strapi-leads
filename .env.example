HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# PostgreSQL (required for production/Render - prevents data loss on deploy)
# When DATABASE_URL is set, Strapi uses Postgres instead of SQLite.
# Get this from your Render PostgreSQL dashboard -> Connect -> Internal URL
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Email - choose ONE method:

# Option A: MailerSend API (recommended - more reliable than SMTP)
# Get from MailerSend Dashboard → Settings → API Tokens → Create token
# MAILERSEND_API_KEY=mlsn.xxxxxxxxxxxxxxxxxxxxxxxx

# Option B: Nodemailer SMTP
# MailerSend: Dashboard → Domains → Manage → SMTP → Generate new user
# SMTP_HOST=smtp.mailersend.net
# SMTP_PORT=587
# SMTP_USERNAME=your_smtp_username
# SMTP_PASSWORD=your_smtp_password

# Required for both:
# MAILER_FROM=noreply@yourdomain.com

# CORS - optional. When set, only these origins can call the API. Comma-separated.
# Leave unset to allow all origins (needed when frontend is on Vercel with dynamic URLs)
# FRONTEND_URL=https://yourapp.vercel.app,https://aiseen.co
